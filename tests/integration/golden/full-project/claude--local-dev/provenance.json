{
  "buildUnit": ".ai-build/claude/local-dev",
  "target": "claude",
  "entries": [
    {
      "sourceObject": "github-mcp",
      "outputFiles": [
        ".mcp.json"
      ]
    },
    {
      "sourceObject": "go-standards",
      "outputFiles": [
        "CLAUDE.md"
      ]
    },
    {
      "sourceObject": "go-testing",
      "outputFiles": [
        ".claude/skills/go-testing/SKILL.md"
